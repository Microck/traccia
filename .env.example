# Local LLM backend credentials.
# Leave values blank here. Put real credentials in your shell or a local .env file.
OPENAI_API_KEY=
CLIPROXYAPI_KEY=

# Optional remote transcription providers used by summarize integrations.
GROQ_API_KEY=
ASSEMBLYAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_API_KEY=

# Optional local transcription overrides.
SUMMARIZE_WHISPER_CPP_BINARY=
SUMMARIZE_WHISPER_CPP_MODEL_PATH=

# Optional Traccia runtime paths.
TRACCIA_LLM_LEASE_PATH=
TRACCIA_VIEWER_FONT_DIR=

# npm launcher maintainer overrides.
TRACCIA_UVX_SPEC=
TRACCIA_USE_LOCAL_REPO=
