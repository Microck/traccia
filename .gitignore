# Local Traccia runs can contain private raw imports, parsed evidence,
# database state, and live API/proxy configuration from E2E testing.
tmp/

# Local graph state and generated viewer exports contain personal skill
# data and binary font assets. The canonical viewer source lives in
# src/traccia/viewer_assets.py and is materialized via `traccia export viewer`.
graph/
exports/

# Local credentials and machine-specific runtime state.
.env
.env.*
!.env.example
.agent-runtime.json

# Local foundry/source font packages for viewer experiments. The canonical
# normalized viewer subset is committed under src/traccia/assets/fonts/.
private/font-assets/
docs/design-drafts/

# Local E2E runner/watchdog wrappers generated during live backend testing.
scripts/traccia-ingest-loop.sh
scripts/traccia-progress-monitor.sh
scripts/traccia-watchdog-loop.sh
scripts/traccia-watchdog.py

